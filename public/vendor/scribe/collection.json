                            "body": "{\n  \"message\": \"The given data was invalid.\",\n  \"errors\": {\n    \"type_id\": [\"O tipo informado n\u00e3o existe.\"],\n    \"location\": [\"O campo location deve ser um ponto GeoJSON v\u00e1lido.\"]\n  }\n}",
                            "name": ""
                        }
                    ]
