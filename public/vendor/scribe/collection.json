                {
                    "name": "Deletar ocorr\u00eancia\n\nEste endpoint permite que um usu\u00e1rio autenticado exclua uma ocorr\u00eancia existente.",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/ocurrences\/:ocurrence_id",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/ocurrences\/:ocurrence_id",
                            "variable": [
                                {
                                    "id": "ocurrence_id",
                                    "key": "ocurrence_id",
                                    "value": "16",
